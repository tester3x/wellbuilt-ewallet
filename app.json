{
  "expo": {
    "name": "WB eWallet",
    "slug": "wellbuilt-ewallet",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "wbewallet",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0A0E1A"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.wellbuilt.ewallet",
      "infoPlist": {
        "NSCameraUsageDescription": "WB eWallet needs camera access to photograph your documents (CDL, medical card, insurance, etc.)",
        "NSPhotoLibraryUsageDescription": "WB eWallet needs photo library access to import document photos"
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/icon.png",
        "backgroundColor": "#0A0E1A"
      },
      "package": "com.wellbuilt.ewallet",
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-splash-screen",
      "expo-secure-store",
      [
        "expo-camera",
        {
          "cameraPermission": "WB eWallet needs camera access to photograph your documents."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "WB eWallet needs photo library access to import document photos."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "eas": {
        "projectId": "855de803-070e-47a3-9ca6-478daf84e814"
      },
      "router": {
        "origin": false
      }
    },
    "owner": "testerxxx"
  }
}
